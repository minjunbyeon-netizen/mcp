# VPS 서버용 .env — /home/dev/work/mcp/.env 에 복사 후 값 채우기

# ── 필수 ────────────────────────────────────────
GEMINI_API_KEY=여기에_Gemini_API_키

# ── Google OAuth (로그인 기능) ───────────────────
GOOGLE_CLIENT_ID=여기에_클라이언트_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=여기에_클라이언트_시크릿

# ── 보안 ────────────────────────────────────────
FLASK_SECRET_KEY=랜덤한_긴_문자열_여기에  # python -c "import secrets; print(secrets.token_hex(32))"

# ── 앱 설정 ─────────────────────────────────────
PORT=5051
APPLICATION_ROOT=/mcp

# ── 선택사항 ─────────────────────────────────────
# UNSPLASH_ACCESS_KEY=언스플래시_키
# ALLOWED_EMAILS=user1@gmail.com,user2@gmail.com
